<?xml version="1.0" encoding="UTF-8"?>
<!--
    fly-CMS — захист директорії data/ на IIS
    Розмістити: C:\inetpub\wwwroot\pass.starkon.gov.ua\data\web.config

    Блокує прямий HTTP-доступ до:
      - database.sqlite (і WAL/SHM файли)
      - логів activity.log
      - PHP-файлів конфігурації
      - lock-файлів rate limiter

    Аналог .htaccess "Deny from all" для Apache.
-->
<configuration>
    <system.webServer>

        <!-- Забороняємо весь HTTP-доступ до директорії data/ -->
        <security>
            <requestFiltering>
                <denyUrlSequences>
                    <!-- Блокуємо будь-який запит що містить /data/ -->
                </denyUrlSequences>
            </requestFiltering>
        </security>

        <!-- Повертаємо 403 на всі запити до цієї директорії -->
        <httpErrors errorMode="Custom" existingResponse="Replace">
            <remove statusCode="403" />
            <error statusCode="403" responseMode="File" path="403.htm" />
        </httpErrors>

        <!-- Головне правило: відхиляємо всі запити -->
        <rewrite>
            <rules>
                <rule name="Block data directory" stopProcessing="true">
                    <match url=".*" />
                    <action type="CustomResponse" statusCode="403"
                            statusReason="Forbidden"
                            statusDescription="Access to this directory is denied." />
                </rule>
            </rules>
        </rewrite>

    </system.webServer>
</configuration>

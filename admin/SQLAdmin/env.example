# ──────────────────────────────────────────────
# fly-CMS — шаблон .env
# Скопіюйте у .env і заповніть значення.
# Зберігайте .env ПОЗА webroot (у FLY_STORAGE_ROOT).
# ──────────────────────────────────────────────

# Шлях до сховища поза webroot (необов'язково — за замовч. ../cms_storage)
# FLY_STORAGE_ROOT=/home/youruser/cms_storage

# ── AI (Groq) ──────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── SMTP ───────────────────────────────────────
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=CMS Admin
SMTP_FROM_EMAIL=noreply@cms.local
SMTP_ENCRYPTION=tls

# ── phpLiteAdmin ───────────────────────────────
PHPLITEADMIN_PASSWORD=замінітьНаСвійПароль

{# views/index.twig — головна сторінка #}
{% extends 'layouts/base.twig' %}

{% block content %}

{# ── HERO ──────────────────────────────────────────────────────────── #}
{% if hero_on %}
<section class="fly-hero" id="hero" style="min-height:{{ hero_height }}px">
  <div class="fly-hero-bg" style="background:{{ hero_bg_col }}{% if hero_bg_img %};background-image:url('{{ hero_bg_img }}');background-size:cover;background-position:center{% endif %}"></div>
  {% if hero_overlay > 0 %}
  <div class="fly-hero-overlay" style="background:rgba(0,0,0,{{ hero_overlay }})"></div>
  {% endif %}
  <div class="fly-hero-content {{ hero_layout == 'centered' ? 'centered' : 'left' }} container py-5"
       style="max-width:{{ container_max }}px;color:{{ hero_color }}">
    <h1 class="display-4 fw-bold mb-3">{{ hero_title }}</h1>
    {% if hero_sub %}
    <p class="lead mb-4" style="opacity:.9;max-width:600px;{{ hero_layout == 'centered' ? 'margin:0 auto 1.5rem' : '' }}">
      {{ hero_sub|nl2br }}
    </p>
    {% endif %}
    <div class="d-flex flex-wrap gap-3 {{ hero_layout == 'centered' ? 'justify-content-center' : '' }}">
      {% if hero_btn1 %}<a href="{{ hero_btn1url }}" class="btn btn-{{ hero_btn1sty }} btn-lg">{{ hero_btn1 }}</a>{% endif %}
      {% if hero_btn2 %}<a href="{{ hero_btn2url }}" class="btn btn-{{ hero_btn2sty }} btn-lg">{{ hero_btn2 }}</a>{% endif %}
    </div>
  </div>
</section>
{% endif %}

{# ── MAIN CONTENT блок ─────────────────────────────────────────────── #}
{% if main_content|striptags|trim %}
<section class="py-4">
  <div class="container" style="max-width:{{ container_max }}px">
    {{ main_content|raw }}
  </div>
</section>
{% endif %}

{# ── EXTRA BLOCK (before_news) ────────────────────────────────────── #}
{% if extra_pos == 'before_news' and extra_html|trim %}
{{ extra_html|raw }}
{% endif %}

{# ── DIVIDER ──────────────────────────────────────────────────────── #}
{% if show_divider %}
<div class="fly-section-divider fly-divider-{{ divider_style }}" aria-hidden="true">
  {% if divider_style == 'wave' %}
  <div class="fly-divider-line"></div>
  <svg viewBox="0 0 1200 {{ divider_height }}" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"
       style="display:block;width:100%;height:{{ divider_height }}px;margin-bottom:-1px">
    <path d="M0,{{ (divider_height * 0.5)|round }} C200,{{ divider_height }} 400,0 600,{{ (divider_height * 0.5)|round }} C800,{{ divider_height }} 1000,0 1200,{{ (divider_height * 0.5)|round }} L1200,{{ divider_height }} L0,{{ divider_height }} Z" fill="{{ divider_color }}"/>
  </svg>
  {% elseif divider_style == 'slope' %}
  <svg viewBox="0 0 1200 {{ divider_height }}" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"
       style="display:block;width:100%;height:{{ divider_height }}px;margin-bottom:-1px">
    <polygon points="0,{{ divider_height }} 1200,0 1200,{{ divider_height }}" fill="{{ divider_color }}"/>
  </svg>
  {% elseif divider_style == 'triangle' %}
  <svg viewBox="0 0 1200 {{ divider_height }}" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"
       style="display:block;width:100%;height:{{ divider_height }}px;margin-bottom:-1px">
    <polygon points="0,{{ divider_height }} 600,0 1200,{{ divider_height }}" fill="{{ divider_color }}"/>
  </svg>
  {% elseif divider_style == 'arc' %}
  <svg viewBox="0 0 1200 {{ divider_height }}" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"
       style="display:block;width:100%;height:{{ divider_height }}px;margin-bottom:-1px">
    <path d="M0,{{ divider_height }} Q600,0 1200,{{ divider_height }} Z" fill="{{ divider_color }}"/>
  </svg>
  {% elseif divider_style == 'zigzag' %}
  <svg viewBox="0 0 1200 {{ divider_height }}" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"
       style="display:block;width:100%;height:{{ divider_height }}px;margin-bottom:-1px">
    <polyline points="0,0 100,{{ divider_height }} 200,0 300,{{ divider_height }} 400,0 500,{{ divider_height }} 600,0 700,{{ divider_height }} 800,0 900,{{ divider_height }} 1000,0 1100,{{ divider_height }} 1200,0 1200,{{ divider_height }} 0,{{ divider_height }}" fill="{{ divider_color }}"/>
  </svg>
  {% elseif divider_style == 'line' %}
  <div style="height:3px;background:linear-gradient(90deg,transparent,{{ divider_color }} 20%,{{ divider_color }} 80%,transparent)"></div>
  <div style="height:{{ divider_height > 3 ? divider_height - 3 : 0 }}px;background:{{ divider_color }}"></div>
  {% elseif divider_style == 'fade' %}
  <div style="height:{{ divider_height }}px;background:linear-gradient(to bottom,transparent,{{ divider_color }})"></div>
  {% elseif divider_style == 'double_line' %}
  <div style="height:2px;background:{{ divider_color }};opacity:.3;margin-bottom:6px"></div>
  <div style="height:4px;background:linear-gradient(90deg,transparent,{{ divider_color }} 15%,{{ divider_color }} 85%,transparent)"></div>
  <div style="height:{{ divider_height > 12 ? divider_height - 12 : 0 }}px;background:{{ divider_color }}"></div>
  {% endif %}
</div>
{% endif %}

{# ── NEWS SECTION ─────────────────────────────────────────────────── #}
{% if news_on and posts|length > 0 %}
<section class="fly-news-section" id="news" style="background:{{ news_bg }}">
  <div class="container" style="max-width:{{ container_max }}px">
    {% if news_title %}
    <h2 class="mb-4">{{ news_title }}</h2>
    {% endif %}

    {% if news_layout == 'list' %}
    {# ── Список ── #}
    <div class="d-flex flex-column gap-3">
      {% for post in posts %}
      <div class="fly-news-card d-flex gap-3 p-3" style="border-radius:{{ card_radius }}px">
        {% if news_thumb and post.thumbnail %}
        <img src="{{ post.thumbnail }}" alt=""
             style="width:140px;height:100px;object-fit:cover;border-radius:{{ card_radius }}px;flex-shrink:0">
        {% endif %}
        <div class="flex-grow-1">
          <h5 class="mb-1">
            <a href="/{{ post.slug }}" class="text-decoration-none">{{ post.title }}</a>
          </h5>
          {% if news_date or news_author %}
          <div class="fly-post-meta mb-2">
            {% if news_author and post.author %}<span><i class="bi bi-person me-1"></i>{{ display_name(post.author) }}</span> {% endif %}
            {% if news_date and post.created_at %}<span><i class="bi bi-calendar3 me-1"></i>{{ post.created_at|date_uk }}</span>{% endif %}
          </div>
          {% endif %}
          {% if news_excerpt %}
          <p class="mb-0 small text-muted">{{ post.content|excerpt(news_ex_len) }}</p>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>

    {% else %}
    {# ── Сітка ── #}
    <div class="row g-4 fly-news-grid">
      {% for post in posts %}
      <div class="col-sm-6 col-md-{{ bs_cols }} fly-news-item">
        <div class="fly-news-card h-100" style="border-radius:{{ card_radius }}px;overflow:hidden">
          {% if news_thumb and post.thumbnail %}
          <div class="fly-news-thumb-wrap" style="height:{{ news_thumb_h }}px">
            <img src="{{ post.thumbnail }}" alt="">
          </div>
          {% endif %}
          <div class="card-body d-flex flex-column p-3">
            <h5 class="card-title mb-2" style="font-size:1rem">
              <a href="/{{ post.slug }}" class="text-decoration-none">{{ post.title }}</a>
            </h5>
            {% if news_date or news_author %}
            <div class="fly-post-meta mb-2">
              {% if news_author and post.author %}<span><i class="bi bi-person me-1"></i>{{ display_name(post.author) }}</span> {% endif %}
              {% if news_date and post.created_at %}<span><i class="bi bi-calendar3 me-1"></i>{{ post.created_at|date_uk }}</span>{% endif %}
            </div>
            {% endif %}
            {% if news_excerpt %}
            <p class="card-text small text-muted flex-grow-1">{{ post.content|excerpt(news_ex_len) }}</p>
            {% endif %}
            {% if news_readmore %}
            <div class="mt-auto pt-2">
              <a href="/{{ post.slug }}" class="btn btn-sm btn-primary">{{ news_rm_text }} <i class="bi bi-arrow-right"></i></a>
            </div>
            {% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>
{% endif %}

{# ── EXTRA BLOCK (after_news) ─────────────────────────────────────── #}
{% if extra_pos == 'after_news' and extra_html|trim %}
{{ extra_html|raw }}
{% endif %}

{% endblock %}

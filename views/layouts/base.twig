{# views/layouts/base.twig — базовий HTML-макет #}
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <title>{{ site_title }}{% if title is defined and title %} — {{ title }}{% endif %}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ meta_description|default('') }}">
  <meta name="keywords"    content="{{ meta_keywords|default('') }}">
  <link rel="icon" href="{{ favicon_path }}" type="image/x-icon">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="{{ asset('css/style.css') }}">
  {% if theme_css_exists %}
  <link rel="stylesheet" href="{{ asset('css/theme.css') }}?v={{ theme_css_mtime }}">
  {% endif %}
  {% if custom_css is defined and custom_css %}
  <style>{{ custom_css|sanitize_css }}</style>
  {% endif %}
  {% block head %}{% endblock %}
  {# LT_CONFIG від плагіна lang-translator #}
  {% if lt_config_json is defined and lt_config_json %}
  {{ lt_config_json|raw }}
  {% endif %}
</head>
<body>

{# ── NAVBAR ─────────────────────────────────────────────────────── #}
<header class="navbar navbar-expand-lg navbar-{{ navbar_style }} {{ navbar_sticky ? 'sticky-top' : '' }} shadow-sm">
  <div class="container" style="max-width:{{ container_max }}px">
    <a class="navbar-brand d-flex align-items-center gap-2" href="/">
      <img src="{{ logo_path }}" alt="Логотип" height="{{ navbar_height > 60 ? 50 : navbar_height - 10 }}">
      <span>{{ site_title }}</span>
    </a>
    <div class="ms-auto d-none d-lg-flex">
      <nav class="navbar-nav flex-row">
        {% from 'partials/menu.twig' import render_items %}
        {{ render_items(menu_tree, false, menu_role, menu_logged) }}
      </nav>
    </div>
    <div class="d-lg-none ms-auto">
      <button class="btn btn-outline-light btn-sm" type="button"
              data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">☰</button>
    </div>
  </div>
</header>

{# ── ОСНОВНИЙ КОНТЕНТ ─────────────────────────────────────────────── #}
<main>
  {% block content %}{% endblock %}
</main>

{# ── FOOTER ──────────────────────────────────────────────────────── #}
<footer class="footer mt-auto">
  <div class="container text-center" style="max-width:{{ container_max }}px">
    <small>{{ footer_text ? footer_text|raw : ('&copy; ' ~ current_year ~ ' ' ~ site_title) }}</small>
    {% if phone or email %}
    <div class="mt-1">
      {% if phone %}<a href="tel:{{ phone|tel }}">{{ phone }}</a>{% endif %}
      {% if phone and email %} &nbsp;|&nbsp; {% endif %}
      {% if email %}<a href="mailto:{{ email }}">{{ email }}</a>{% endif %}
    </div>
    {% endif %}
    {% if address %}
    <div class="mt-1 small">{{ address|nl2br }}</div>
    {% endif %}
    {# Switcher у footer (плагін lang-translator) #}
    {% if lt_footer_html is defined and lt_footer_html %}
    <div class="mt-2">{{ lt_footer_html|raw }}</div>
    {% endif %}
  </div>
</footer>

{# ── Мобільне меню (offcanvas) ────────────────────────────────────── #}
<div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title">Меню</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body">
    {% from 'partials/menu.twig' import render_items %}
    <ul class="nav flex-column">
      {{ render_items(menu_tree, true, menu_role, menu_logged) }}
    </ul>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{# lang-widget.js — підключається якщо плагін активний (lt_config_json встановлено) #}
{% if lt_config_json is defined and lt_config_json %}
<script src="/assets/js/lang-widget.js"></script>
{% endif %}
{% if custom_js is defined and custom_js %}
<script>{{ custom_js|sanitize_js }}</script>
{% endif %}
{% block scripts %}{% endblock %}
{# Floating switcher (плагін lang-translator) #}
{% if lt_floating_html is defined and lt_floating_html %}
{{ lt_floating_html|raw }}
{% endif %}

{# ── Кнопка прокрутки вгору ───────────────────────────────────── #}
<button id="scrollTopBtn" aria-label="Прокрутити вгору" onclick="window.scrollTo({top:0,behavior:'smooth'})" style="
    display:none; position:fixed; right:24px; z-index:9990;
    width:42px; height:42px; border-radius:50%; border:none; cursor:pointer;
    background:#1e3a6e; color:#fff; font-size:18px; line-height:1;
    box-shadow:0 3px 12px rgba(0,0,0,.25); transition:opacity .2s, transform .2s;
    align-items:center; justify-content:center;">↑</button>
<script>
(function(){
    var btn = document.getElementById('scrollTopBtn');
    if (!btn) return;
    // Якщо є floating перемикач мов — розміщуємо під ним
    var hasFloating = window.LT_CONFIG && window.LT_CONFIG.position === 'floating';
    btn.style.bottom = hasFloating ? '78px' : '24px';
    window.addEventListener('scroll', function(){
        if (window.scrollY > 300) {
            btn.style.display = 'flex';
            btn.style.opacity = '1';
        } else {
            btn.style.opacity = '0';
            setTimeout(function(){ if(window.scrollY<=300) btn.style.display='none'; }, 200);
        }
    }, { passive: true });
    btn.onmouseenter = function(){ btn.style.transform='scale(1.1)'; };
    btn.onmouseleave = function(){ btn.style.transform='scale(1)'; };
})();
</script>
</body>
</html>

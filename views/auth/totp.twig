{# views/auth/totp.twig — двофакторна автентифікація #}
<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8"><title>Двофакторна автентифікація</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
.totp-input{font-size:2rem;letter-spacing:.5rem;text-align:center;font-family:monospace}
.timer-bar{height:4px;background:#e9ecef;border-radius:2px;overflow:hidden;margin-top:8px}
.timer-fill{height:100%;background:#198754;transition:width 1s linear}
</style>
</head>
<body class="bg-light">
<div class="container d-flex justify-content-center align-items-center" style="min-height:100vh">
<div style="max-width:400px;width:100%">
<div class="card shadow-sm">
<div class="card-body p-4">
  <div class="text-center mb-3">
    <div style="font-size:3rem">🛡️</div>
    <h4 class="fw-bold">Двофакторна автентифікація</h4>
    <p class="text-muted small">Введіть 6-значний код з додатку<br><strong>Google Authenticator</strong></p>
  </div>
  {% if error %}
  <div class="alert alert-danger py-2 small">{{ error }}</div>
  {% endif %}
  <form method="POST" autocomplete="off" id="totpForm">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <div class="mb-3">
      <input type="text" name="totp_code" class="form-control totp-input"
             maxlength="6" pattern="[0-9]{6}" inputmode="numeric"
             placeholder="000000" autofocus required autocomplete="one-time-code">
      <div class="timer-bar"><div class="timer-fill" id="timerFill"></div></div>
      <div class="text-end"><small class="text-muted" id="timerText"></small></div>
    </div>
    <button type="submit" class="btn btn-primary w-100">✅ Підтвердити</button>
  </form>
  <div class="text-center mt-3">
    <a href="/templates/login.php?cancel_2fa=1" class="text-muted small">← Повернутися до входу</a>
  </div>
</div>
</div>
</div>
</div>
<script>
document.querySelector('input[name="totp_code"]').addEventListener('input', function() {
  if (this.value.length === 6 && /^\d{6}$/.test(this.value)) {
    document.getElementById('totpForm').submit();
  }
});
function updateTimer() {
  var now = Math.floor(Date.now() / 1000);
  var rem = 30 - (now % 30);
  var pct = (rem / 30) * 100;
  document.getElementById('timerFill').style.width = pct + '%';
  document.getElementById('timerText').textContent = rem + ' сек';
  document.getElementById('timerFill').style.background = rem <= 5 ? '#dc3545' : '#198754';
}
updateTimer(); setInterval(updateTimer, 1000);
</script>
</body>
</html>
